COMPOSE_PROJECT_NAME=spacesio

# --- Backend API Configuration ---
API_PORT=8080
JWT_SECRET=<your_secure_random_string>

# --- Database (PostgreSQL) ---
# For local Docker: postgres://admin:securepassword@system_db:5432/erp_v1?sslmode=disable
# For host access: postgres://admin:securepassword@localhost:5434/erp_v1?sslmode=disable
DATABASE_URL=postgres://admin:securepassword@postgres:5432/erp_v1?sslmode=disable

# --- Cache (Redis) ---
# For local Docker: redis://system_cache:6379/0
# For host access: redis://localhost:6380/0
REDIS_URL=redis://redis:6379/0

# --- Message Broker (RabbitMQ) ---
# For local Docker: amqp://guest:guest@system_mq:5672/
# For host access: amqp://guest:guest@localhost:5672/
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- Object Storage (MinIO) ---
# For local Docker: system_storage:9000
# For host access: localhost:9001
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=securepassword
MINIO_BUCKET=crm-files
MINIO_USE_SSL=false

# --- HR & Attendance ---
OFFICE_IP=0.0.0.0

# --- WhatsApp (Meta Cloud API) ---
WHATSAPP_TOKEN=<your_whatsapp_token>
WHATSAPP_PHONE_ID=<your_whatsapp_phone_id>
WHATSAPP_TEMPLATE_NAMESPACE=<your_template_namespace_here>

# --- Docker Compose Specific (Optional if defined in docker-compose.yml) ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=securepassword
POSTGRES_DB=erp_v1
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=securepassword
