        },
        {
          "name": "Test Ping (RabbitMQ)",
          "request": {
            "method": "POST",
            "url": "{{base}}/api/v1/test/ping"
          }
        }
      ]
    },
    {
      "name": "1. IAM",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base}}/api/v1/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"admin@company.com\",\"password\":\"admin123\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var j=pm.response.json();if(j.access_token){pm.collectionVariables.set('token',j.access_token);}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{base}}/api/v1/users/me"
          }
        },
        {
          "name": "Setup PINs (Super Admin)",
          "request": {
            "method": "POST",
            "url": "{{base}}/api/v1/iam/setup-pins",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"normal_pin\":\"1234\",\"confirm_normal_pin\":\"1234\",\"high_security_pin\":\"567890\",\"confirm_high_security_pin\":\"567890\"}"
            }
          }
        },
        {
          "name": "Verify PIN (Normal)",
          "request": {
            "method": "POST",
            "url": "{{base}}/api/v1/iam/verify-pin",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"pin\":\"1234\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var j=pm.response.json();if(j.access_token){pm.collectionVariables.set('pin_token',j.access_token);pm.collectionVariables.set('token',j.access_token);}"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify PIN (Ghost Mode)",
          "request": {
            "method": "POST",
            "url": "{{base}}/api/v1/iam/verify-pin",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"pin\":\"567890\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var j=pm.response.json();if(j.access_token){pm.collectionVariables.set('pin_token',j.access_token);pm.collectionVariables.set('token',j.access_token);}"
                ]
              }
            }
          ]
        },
